<!DOCTYPE html>
{%- set htmlTitle = metaTitle or (title + " — BuilderFox") %}
{%- set metaDesc = metaDescription or description %}
{%- set canonicalUrl = "https://builderfox.com" + page.url %}
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ htmlTitle }}</title>
  <meta name="description" content="{{ metaDesc }}">
  {%- if noindex %}
  <meta name="robots" content="noindex">
  {%- else %}
  <meta name="robots" content="index, follow, max-image-preview:large">
  <link rel="canonical" href="{{ canonicalUrl }}">
  {%- endif %}
  <meta name="theme-color" content="#0B1810">
  <script>document.documentElement.classList.add('js');</script>

  {%- set ogImg = ogImage or "https://builderfox.com/assets/og-image.png" %}
  {%- set ogImgWidth = ogImageWidth or 1200 %}
  {%- set ogImgHeight = ogImageHeight or 630 %}
  {%- set ogImgAlt = ogImageAlt or "BuilderFox mark — a green fox head in profile within a sweeping crescent arc, with a crimson ring accent below the jaw — beside the BuilderFox wordmark in cream and lime on a deep pine-green board with a faint tactical grid and soft pools of stadium light" %}
  <meta property="og:type" content="{{ ogType or "website" }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:site_name" content="BuilderFox">
  <meta property="og:title" content="{{ htmlTitle }}">
  <meta property="og:description" content="{{ metaDesc }}">
  {%- if not noindex %}
  <meta property="og:url" content="{{ canonicalUrl }}">
  {%- endif %}
  <meta property="og:image" content="{{ ogImg }}">
  <meta property="og:image:width" content="{{ ogImgWidth }}">
  <meta property="og:image:height" content="{{ ogImgHeight }}">
  <meta property="og:image:alt" content="{{ ogImgAlt }}">
  {%- if ogType == "article" %}
  <meta property="article:published_time" content="{{ page.date | isoDate }}">
  {%- endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ htmlTitle }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta name="twitter:image" content="{{ ogImg }}">

  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="alternate icon" href="/assets/favicon-32.png" type="image/png" sizes="32x32">
  <link rel="alternate" type="application/atom+xml" title="BuilderFox — Dev Blog" href="/feed.xml">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&amp;family=Inter:wght@400;500;600&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="/assets/theme.js" defer></script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://builderfox.com/#organization",
        "name": "BuilderFox",
        "url": "https://builderfox.com/",
        "logo": "https://builderfox.com/assets/logo.svg",
        "email": "aaron@builderfox.com",
        "description": "BuilderFox is a creative agency that builds and publishes digital games — smart, tactical games where thinking is the fun part."
      },
      {
        "@type": "WebSite",
        "@id": "https://builderfox.com/#website",
        "name": "BuilderFox",
        "url": "https://builderfox.com/",
        "publisher": { "@id": "https://builderfox.com/#organization" }
      }
      {%- if schema == "game" %},
      {
        "@type": "VideoGame",
        "@id": "{{ canonicalUrl }}#game",
        "name": "Wrestling City Tactics",
        "url": {{ canonicalUrl | dump | safe }},
        "image": "https://builderfox.com/assets/wct-cover.jpg",
        "description": {{ description | dump | safe }},
        "genre": ["Turn-based tactics", "RPG", "Strategy"],
        "author": { "@id": "https://builderfox.com/#organization" },
        "publisher": { "@id": "https://builderfox.com/#organization" },
        "inLanguage": "en"
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://builderfox.com/" },
          { "@type": "ListItem", "position": 2, "name": "Wrestling City Tactics", "item": {{ canonicalUrl | dump | safe }} }
        ]
      }
      {%- endif %}
      {%- if faqs %},
      {
        "@type": "FAQPage",
        "mainEntity": [
          {%- for item in faqs %}
          {
            "@type": "Question",
            "name": {{ item.q | dump | safe }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ item.a | dump | safe }}
            }
          }{{ "," if not loop.last }}
          {%- endfor %}
        ]
      }
      {%- endif %}
      {%- if schema == "blog" %},
      {
        "@type": "Blog",
        "@id": "{{ canonicalUrl }}#blog",
        "name": "From the Den — BuilderFox Dev Blog",
        "url": {{ canonicalUrl | dump | safe }},
        "publisher": { "@id": "https://builderfox.com/#organization" }
      }
      {%- endif %}
      {%- if schema == "post" %},
      {
        "@type": "BlogPosting",
        "headline": {{ title | dump | safe }},
        "description": {{ description | dump | safe }},
        "datePublished": "{{ page.date | isoDate }}",
        "dateModified": "{{ page.date | isoDate }}",
        "author": { "@id": "https://builderfox.com/#organization" },
        "publisher": { "@id": "https://builderfox.com/#organization" },
        "mainEntityOfPage": {{ canonicalUrl | dump | safe }},
        "image": "https://builderfox.com/assets/og-image.png",
        "inLanguage": "en"
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://builderfox.com/" },
          { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://builderfox.com/blog/" },
          { "@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": {{ canonicalUrl | dump | safe }} }
        ]
      }
      {%- endif %}
    ]
  }
  </script>
</head>
<body>

  <!-- the table: pine felt, ambient pools, vignette, grain -->
  <div class="felt" aria-hidden="true">
    <div class="felt-pools"></div>
    <div class="felt-weave"></div>
    <div class="felt-vignette"></div>
    <div class="felt-grain"></div>
  </div>

  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="container header-row">
      <a class="brand" href="/" aria-label="BuilderFox — home">
        <span class="brand-mark"><img src="/assets/logo.svg" alt="" width="36" height="36"></span>
        <span class="brand-name">Builder<span>Fox</span></span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/wrestling-city-tactics/"{% if page.url == "/wrestling-city-tactics/" %} aria-current="page"{% endif %}>Wrestling City Tactics</a>
        <a href="/blog/"{% if page.url == "/blog/" %} aria-current="page"{% elif "/blog/" in page.url %} aria-current="true"{% endif %}>Blog</a>
        <a href="#contact">Contact</a>
      </nav>
      <span class="turnchip" aria-hidden="true">Turn&nbsp;<b data-turnview>01</b><i>/{{ turnTotal or "01" }}</i></span>
    </div>
    <!-- board ruler: the page sits on these columns -->
    <div class="ruler" aria-hidden="true">
      <div class="container ruler-row">
        <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span>
        <span>G</span><span>H</span><span>I</span><span>J</span><span>K</span><span>L</span>
      </div>
    </div>
  </header>

  <main id="main">
{{ content | safe }}
  </main>

  <footer id="contact" class="site-footer">
    <h2 class="visually-hidden">Contact</h2>
    <p class="footer-ghost" aria-hidden="true">BuilderFox</p>
    <div class="container footer-grid">
      <p class="match-end" aria-hidden="true"><span class="slashes">//</span> End of match &mdash; Turn {{ turnTotal or "01" }}/{{ turnTotal or "01" }}</p>
      <div class="footer-brand">
        <img src="/assets/logo.svg" alt="" width="48" height="48">
        <span class="brand-name">Builder<span>Fox</span></span>
      </div>
      <p class="footer-contact">Got a move to discuss? <a href="mailto:aaron@builderfox.com">aaron@builderfox.com</a></p>
      <p class="signoff">Built in the den. Plotted everywhere else.</p>
      <div class="footer-meta">
        <p class="legal">&copy; 2026 BuilderFox. All artwork original. No likenesses harmed.</p>
        <p class="domain">builderfox.com</p>
      </div>
    </div>
  </footer>
</body>
</html>
